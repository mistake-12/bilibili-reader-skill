# B站Cookie（必填，运行 python -m src --login 可自动获取）
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_BUVID3=

# 输出目录（可选）
OUTPUT_DIR=./output

# 数据目录（可选）
DATA_DIR=./data

# 高赞评论数量（可选，默认10）
MAX_COMMENTS=10

# 弹幕数量（可选，默认50）
MAX_DANMAKUS=50

# 推送平台（可选，生成PDF后自动推送到指定平台）
# 可选值：wechat / feishu / telegram / discord / slack / whatsapp / none
# 设置后 agent 会自动将PDF推送到其默认对话
DELIVERY_PLATFORM=none
